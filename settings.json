{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "120000",
    "BASH_MAX_TIMEOUT_MS": "600000",
    "MAX_MCP_OUTPUT_TOKENS": "25000"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git fetch:*)",
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(yarn:*)",
      "Bash(npx eslint:*)",
      "Bash(npx jest:*)",
      "Bash(npx tsc:*)",
      "Bash(ls:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(diff:*)",
      "Bash(jq:*)",
      "Bash(test:*)",
      "Bash(echo:*)",
      "Bash(date:*)",
      "Bash(xargs:*)",
      "Bash(tee:*)",
      "Bash(make:*)",
      "Bash(curl:*)",
      "Bash(claude:*)",
      "Bash(gh:*)",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf .)",
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git push -f*)",
      "Bash(git push * +*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git checkout -- .)",
      "Bash(git restore .)",
      "Bash(git branch -D*)",
      "Bash(chmod 777*)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(curl * | zsh)",
      "Bash(curl * | python*)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | python*)",
      "Bash(eval *curl*)",
      "Bash(eval *wget*)",
      "Bash(cat ~/.ssh/*)",
      "Bash(cp ~/.ssh/*)",
      "Bash(scp ~/.ssh/*)",
      "Bash(base64 ~/.ssh/*)",
      "Bash(cat */.env*)",
      "Bash(cp */.env*)",
      "Bash(scp */.env*)",
      "Bash(base64 */.env*)",
      "Bash(cat *credentials*)",
      "Bash(cp *credentials*)",
      "Bash(scp *credentials*)",
      "Bash(base64 *credentials*)",
      "Bash(npm publish*)",
      "Bash(pnpm publish*)",
      "Edit(~/dotfiles/**)",
      "Edit(~/.claude/**)",
      "Write(~/dotfiles/**)",
      "Write(~/.claude/**)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git commit *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git stash *)",
      "Bash(git tag *)",
      "Bash(docker *)",
      "Bash(rm *)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh ~/.claude/audit-log.sh",
            "timeout": 2
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if command -v osascript >/dev/null 2>&1; then osascript -e 'display notification \"Claude Code needs your attention\" with title \"Claude Code\"'; elif command -v notify-send >/dev/null 2>&1; then notify-send 'Claude Code' 'Claude Code needs your attention'; fi",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "figma@claude-plugins-official": true,
    "redis-development@redis": true
  },
  "extraKnownMarketplaces": {
    "redis": {
      "source": {
        "source": "git",
        "url": "https://github.com/redis/agent-skills.git"
      }
    }
  },
  "language": "Korean",
  "showTurnDuration": true
}
